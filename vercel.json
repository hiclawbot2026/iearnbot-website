{
  "version": 2,
  "name": "iearnbot-website",
  "public": true,
  "outputDirectory": "public",
  "functions": {
    "api/*.js": {
      "maxDuration": 60
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "github": {
    "silent": true
  }
}
