# iEarn.Bot — Environment Variables
# Copy this to .env and fill in your values

# ── SkillPay Billing ───────────────────────────────
SKILLPAY_API_KEY=sk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SKILLPAY_USER_ID=your_telegram_id_or_wallet_address

# ── AI / OpenRouter (optional, for Max tier) ───────
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxx
AI_MODEL=anthropic/claude-3-haiku

# ── Polymarket / Polygon ───────────────────────────
POLYGON_PRIVATE_KEY=your_wallet_private_key
POLYMARKET_API_KEY=your_polymarket_api_key
